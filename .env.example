# Environmental Conservation Website Backend Configuration
# Copy this file to .env and fill in the appropriate values

# Server Port
PORT=3000

# Admin API Key - Change this to a secure random string
# You can generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_API_KEY=shemygirl123

# Payment mode
# live = real money transactions only (recommended for production)
# demo = fallback to simulated transactions
PAYMENT_MODE=live

# Flutterwave Configuration (Required when PAYMENT_MODE=live)
# Get your keys from: https://dashboard.flutterwave.com
FLW_SECRET_KEY=your_flutterwave_live_secret_key

# Flutterwave API Base URL (Usually doesn't need to change)
FLW_BASE_URL=https://api.flutterwave.com/v3

# Database location (relative path)
DB_PATH=./data/geci.db

# Environment
NODE_ENV=development
